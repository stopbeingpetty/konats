# Konats — Environment variables
# Copy this file to .env (gitignored) and fill in real values.

# Supabase — public values (safe to expose to frontend)
VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key-here

# Supabase — service role key (NEVER expose to frontend; only used server-side / Edge Functions)
# Used for the daily backup Edge Function
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# Optional: Phobs API (Phase 3, leave blank for now)
PHOBS_API_BASE_URL=
PHOBS_API_KEY=
PHOBS_HOTEL_ID=
